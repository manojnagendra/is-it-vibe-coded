{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/history",
      "destination": "/api/history.py"
    },
    {
      "source": "/api/audit",
      "destination": "/api/audit.py"
    },
    {
      "source": "/api/vote",
      "destination": "/api/vote.py"
    },
    {
      "source": "/api/comment",
      "destination": "/api/comment.py"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
